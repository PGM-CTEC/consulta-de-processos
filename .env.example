# ============================================
# Consulta Processual - Environment Configuration
# ============================================
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your actual values (never commit .env)
# 3. See README.md for detailed setup guide
# ============================================

# --------------------------------------------
# REQUIRED - Application will fail without these
# --------------------------------------------

# DataJud API Key (OBRIGATÓRIO)
# Como obter:
#   1. Acesse o portal DataJud: https://datajud.cnj.jus.br
#   2. Faça login ou registre-se
#   3. Vá em "API Keys" e gere uma nova chave
#   4. Cole a chave Base64 abaixo
# Formato: Base64 string (ex: cDZHYzlZa0JadVREZDJCendQbXY6...)
DATAJUD_API_KEY=your_datajud_api_key_here

# Database URL (SQLite local)
# Default: SQLite local (não precisa alterar para desenvolvimento)
# Produção: considere PostgreSQL (ex: postgresql://user:pass@host:5432/db)
DATABASE_URL=sqlite:///./consulta_processual.db

# --------------------------------------------
# OPTIONAL - Features work without these
# --------------------------------------------

# CORS Origins (comma-separated)
# Default: Frontend local (http://localhost:5173)
# Produção: adicionar domínio real (ex: https://app.example.com)
ALLOWED_ORIGINS=http://localhost:5173

# Sentry Error Tracking (OPCIONAL - Story: ERROR-ARCH-002)
# Como obter:
#   1. Acesse https://sentry.io/signup
#   2. Crie um projeto FastAPI
#   3. Copie o DSN (formato: https://xxxxx@oxxxxx.ingest.sentry.io/nnnnnnn)
#   4. Cole abaixo
# Deixe vazio para desabilitar error tracking
SENTRY_DSN=

# Sentry Features:
# - Error aggregation e grouping automático
# - Alert rules (ex: 5+ errors/hour → notification)
# - Integração com Slack para alertas
# - Traces e performance monitoring (traces_sample_rate=0.1 = 10% de traces)
# Documentação: https://docs.sentry.io/platforms/python/guides/fastapi/

# Environment Mode
# Valores: development | staging | production
ENVIRONMENT=development

# Debug Mode
# Valores: true | false
DEBUG=true

# Logging Level
# Valores: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# NEVER log API keys (security risk)
LOG_API_KEYS=false

# --------------------------------------------
# Rate Limiting (OPCIONAL - disabled por padrão)
# --------------------------------------------

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=false

# Requests per minute per IP
RATE_LIMIT_PER_MINUTE=60

# Maximum concurrent DataJud API calls in bulk operations
# Default: 10 (adjust based on API limits and network)
# Increase for better performance if API allows
# Decrease if getting rate limited or connection timeouts
BULK_MAX_CONCURRENT=10

# --------------------------------------------
# Authentication (OPCIONAL - disabled por padrão)
# --------------------------------------------

# Require API key authentication
REQUIRE_AUTH=false

# Comma-separated valid API keys (if REQUIRE_AUTH=true)
VALID_API_KEYS=

# --------------------------------------------
# AI Integration (OPCIONAL - feature experimental)
# --------------------------------------------

# AI Model for classification/analysis
# Default: google/gemini-2.0-flash-001 (via OpenRouter)
# Deixe vazio para desabilitar features de AI
AI_MODEL=google/gemini-2.0-flash-001

# --------------------------------------------
# AIOS Framework (se estiver usando AIOS)
# --------------------------------------------

NODE_ENV=development
AIOS_VERSION=2.2.0

# --------------------------------------------
# REMOVED (Dead Code)
# --------------------------------------------
# OPENROUTER_API_KEY - Feature removida em 2026-02-22 (REM-008)
# OPENAI_API_KEY - Não utilizada pelo projeto
# DEEPSEEK_API_KEY - AIOS framework apenas
# ANTHROPIC_API_KEY - AIOS framework apenas
