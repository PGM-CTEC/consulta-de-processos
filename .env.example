# ============================================
# Consulta Processo - Environment Configuration
# ============================================
# DO NOT commit real .env file - only .env.example with placeholder values
# Copy this file to .env and fill in your actual values
# ============================================

# Application Environment
NODE_ENV=development
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=Consulta Processual API
VERSION=0.1.0

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:///./consulta_processual.db
DATABASE_ECHO=false

# ============================================
# CRITICAL SECRETS - Obtained from DataJud
# ============================================
# DataJud API Key (required)
# Get your key at: https://www.cnj.jus.br/systpres/?pagina=datajud
# Format: base64-encoded credentials
DATAJUD_API_KEY=your_datajud_api_key_here

# ============================================
# Optional: Error Monitoring
# ============================================
# Sentry DSN for error tracking
# Get your key at: https://sentry.io/
# Leave empty to disable Sentry
SENTRY_DSN=

# ============================================
# Security - CORS
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60

# ============================================
# Bulk Processing
# ============================================
# Maximum concurrent DataJud API calls
BULK_MAX_CONCURRENT=10

# ============================================
# Authentication (optional)
# ============================================
REQUIRE_AUTH=false
VALID_API_KEYS=

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_API_KEYS=false
