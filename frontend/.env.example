# ============================================
# Consulta Processual - Frontend Configuration
# ============================================
# SETUP:
# 1. Copy to .env.development: cp .env.example .env.development
# 2. Or copy to .env.production for production build
# 3. Restart Vite dev server after changes (npm run dev)
# ============================================

# --------------------------------------------
# API Configuration
# --------------------------------------------

# Backend API Base URL (usado por api.js)
# Desenvolvimento: http://localhost:8000 (FastAPI local - porta padrão)
# Produção: https://api.yourapp.com
VITE_API_BASE_URL=http://localhost:8000

# Backend URL para Vite proxy (dev server)
# Usado pelo vite.config.js para proxy /processes, /health, etc.
# Default: http://127.0.0.1:8000
VITE_BACKEND_URL=http://127.0.0.1:8000

# API Request Timeout (milliseconds)
# Default: 30000ms (30 segundos)
# Aumentar se DataJud API estiver lenta ou para buscas bulk grandes
VITE_API_TIMEOUT=30000

# --------------------------------------------
# Application Settings
# --------------------------------------------

# Environment name (informational)
# Valores: development | staging | production
VITE_ENVIRONMENT=development

# Enable debug logging in browser console
# Valores: true | false
# Recomendado: true em dev, false em produção
VITE_DEBUG=true

# --------------------------------------------
# NOTES
# --------------------------------------------
# - Variáveis VITE_* são públicas (expostas ao browser)
# - NUNCA coloque secrets/API keys aqui (use backend para isso)
# - import.meta.env.DEV é built-in do Vite (true em dev mode)
# - Alterar .env requer restart do dev server
