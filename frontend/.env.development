# Development Environment Configuration

# API Base URL - usa proxy relativo (/) pois Vite proxy redireciona para backend
VITE_API_BASE_URL=/

# Backend URL para Vite proxy (usado por vite.config.js)
VITE_BACKEND_URL=http://127.0.0.1:8000

# Timeout
VITE_API_TIMEOUT=30000

# Environment
VITE_ENVIRONMENT=development

# Debug mode (mostrar logs no console)
VITE_DEBUG=true
